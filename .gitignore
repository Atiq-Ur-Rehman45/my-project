# ── PYTHON ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env

# ── LOGS ────────────────────────────────────────────────────────────────────
logs/*.log
*.log

# ── MODELS & BINARIES ───────────────────────────────────────────────────────
# We ignore the heavy models and generated databases
models/*.onnx
models/*.pkl
models/*.xml

# ── RUNTIME DATA (SENSITIVE) ───────────────────────────────────────────────
# We ignore ALL person photos and surveillance snapshots for privacy
data/criminal_db/**/*
data/captured_faces/**/*
data/training_data/**/*
data/uploads/**/*
data/uploaded_videos/**/*
data/*.db
data/*.db-journal
data/*.pkl

# Keep the folder structure by allowing .gitkeep files
!data/criminal_db/.gitkeep
!data/captured_faces/.gitkeep
!data/training_data/.gitkeep
!data/uploads/.gitkeep
!data/uploaded_videos/.gitkeep

# ── IDE & SYSTEM ────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini